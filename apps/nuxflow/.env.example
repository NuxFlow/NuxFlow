# Database — choose one:
#
# Option A (default): Cloudflare D1
# No env vars needed — the DB binding in wrangler.toml handles the connection.
# For local dev with D1: wrangler dev (uses remote D1 preview DB automatically)
#
# Option B: Turso (set both vars and remove the [[d1_databases]] block in wrangler.toml)
NUXT_TURSO_URL=libsql://your-db-name.turso.io
NUXT_TURSO_AUTH_TOKEN=

# Better Auth
NUXT_BETTER_AUTH_SECRET=change-me-32-chars-minimum

# Social login — Google OAuth (optional)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI to add: http://localhost:3000/api/auth/callback/google (dev)
#                                  https://yourdomain.com/api/auth/callback/google (prod)
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

# Social login — GitHub OAuth (optional)
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github (dev)
#                              https://yourdomain.com/api/auth/callback/github (prod)
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=

# Cloudflare Images (optional)
NUXT_CLOUDFLARE_IMAGES_TOKEN=
NUXT_CLOUDFLARE_ACCOUNT_ID=
NUXT_CLOUDFLARE_IMAGES_DELIVERY_URL=

# Email provider: console | resend | brevo | zepto | smtp
NUXT_EMAIL_PROVIDER=console
NUXT_RESEND_API_KEY=
NUXT_BREVO_API_KEY=
NUXT_ZEPTO_API_KEY=
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=
NUXT_SMTP_PASS=

# Public (exposed to client)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
