{
  "name": "@nuxflow/app",
  "version": "2.0.0-beta.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
    "build:demo": "cross-env NODE_OPTIONS=--max-old-space-size=4096 NUXT_IS_DEMO_BUILD=true nuxt build",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run --config vitest.config.ts && vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "deploy": "wrangler deploy",
    "migrate": "pnpm --filter @nuxflow/db migrate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.1",
    "@ai-sdk/openai": "^4.0.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@better-auth/passkey": "^1.6.22",
    "@libsql/client": "^0.14.0",
    "@nuxflow/db": "workspace:*",
    "@nuxflow/canvas": "workspace:*",
    "@nuxflow/plugin-sdk": "workspace:*",
    "@nuxt/ui-pro": "^3.3.7",
    "@nuxtjs/i18n": "^9.5.6",
    "@nuxtjs/turnstile": "^1.1.3",
    "@onmax/nuxt-better-auth": "alpha",
    "@pinia/nuxt": "^0.11.3",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "ai": "^7.0.3",
    "better-auth": "^1.6.22",
    "drizzle-orm": "0.45.2",
    "fflate": "^0.8.3",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "highlight.js": "^11.11.1",
    "nuxt-seo-utils": "^8.3.1",
    "openai": "^6.45.0",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "stripe": "^22.3.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "happy-dom": "^20.10.6",
    "nuxt": "^4.4.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
  }
}
