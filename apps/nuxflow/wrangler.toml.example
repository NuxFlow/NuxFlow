name = "nuxflow"
main = ".output/server/index.mjs"
compatibility_date = "2026-04-01"
compatibility_flags = ["nodejs_compat"]

[build]
command = "pnpm run build"

[assets]
directory = ".output/public"

[vars]
# Set production values in the Cloudflare dashboard or via:
#   wrangler secret put SECRET_NAME
# All names below are install-wide fallbacks read via Nuxt runtimeConfig — the NUXT_
# prefix is required for Nuxt to pick them up. Cloudflare Images, S3, and Bunny.net are
# also configurable per-site in Settings → Media, which takes priority over these.
# NUXT_BETTER_AUTH_SECRET =
# NUXT_CLOUDFLARE_IMAGES_TOKEN =
# NUXT_CLOUDFLARE_ACCOUNT_ID =
#
# S3-compatible storage (checked after Cloudflare Images)
# NUXT_S3_BUCKET =
# NUXT_S3_ACCESS_KEY =
# NUXT_S3_SECRET_KEY =
# NUXT_S3_REGION = "us-east-1"
# NUXT_S3_ENDPOINT =
# NUXT_S3_PUBLIC_URL =
#
# Bunny.net storage (checked last, after Cloudflare Images and S3)
# NUXT_BUNNY_API_KEY =
# NUXT_BUNNY_STORAGE_ZONE =
# NUXT_BUNNY_PULL_ZONE =

[triggers]
# Scheduled publish — runs every minute
crons = ["* * * * *"]

# Dynamic plugin KV store — run to create:
#   wrangler kv namespace create PLUGIN_KV
# then paste the returned id below and in the preview_id field.
[[kv_namespaces]]
binding = "PLUGIN_KV"
id = "your-kv-namespace-id"
preview_id = "your-kv-preview-namespace-id"

# Dynamic Workers loader — spawns isolated Worker instances from code stored in KV.
# Requires compatibility_date >= 2026-03-02.
[[worker_loaders]]
binding = "LOADER"

# Cloudflare Analytics Engine (optional — included in Workers Paid plan).
# Enables edge-native, cookie-free page view and event analytics.
# Create a dataset in the Cloudflare dashboard, then set the binding name to "AE".
# [[analytics_engine_datasets]]
# binding = "AE"
# dataset = "nuxflow_analytics"

# Cloudflare D1 database — the only supported production database.
# Create with: wrangler d1 create nuxflow
# Then paste the returned database_id below.
# Migrations run automatically on the first request after deployment.
[[d1_databases]]
binding = "DB"
database_name = "nuxflow"
database_id = "your-d1-database-id"

# Argon2id password hasher — separate Worker accessed via service binding.
# Deploy first: cd workers/argon2-hasher && pnpm install && pnpm run deploy
# The service name must match the `name` field in workers/argon2-hasher/wrangler.toml.
[[services]]
binding = "ARGON2"
service = "nuxflow-argon2"

# Cloudflare Email Sending — native transactional email, no third-party account or API
# key needed (this is the recommended email provider; select "Cloudflare Email" in
# Settings → Email). Requires each sending domain to be onboarded once:
#   wrangler email sending enable <your-domain>
# Add "remote = true" if you want local dev sends to actually go out via the real
# service instead of failing with a binding-not-found error.
[[send_email]]
name = "EMAIL"
