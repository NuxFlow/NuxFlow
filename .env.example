# Database — Cloudflare D1 is the only supported backend.
# No env vars needed — the [[d1_databases]] binding in wrangler.toml handles the
# connection. `wrangler dev` auto-provisions a local D1 database automatically.

# Better Auth
NUXT_BETTER_AUTH_SECRET=change-me-32-chars-minimum

# Cloudflare Images (optional)
NUXT_CLOUDFLARE_IMAGES_TOKEN=
NUXT_CLOUDFLARE_ACCOUNT_ID=
NUXT_CLOUDFLARE_IMAGES_DELIVERY_URL=

# Cloudflare Stream (optional)
NUXT_CLOUDFLARE_STREAM_TOKEN=

# S3-compatible storage (optional alternative to Cloudflare Images — checked next in
# priority order). These are per-site overridable in Settings → Media too; these env
# vars are only the install-wide fallback when no per-site value is set.
# Setting NUXT_S3_BUCKET automatically activates the S3 provider.
# NUXT_S3_BUCKET=
# NUXT_S3_ACCESS_KEY=
# NUXT_S3_SECRET_KEY=
# NUXT_S3_REGION=us-east-1
# NUXT_S3_ENDPOINT=
# NUXT_S3_PUBLIC_URL=

# Bunny.net storage (checked last, after Cloudflare Images and S3 above)
# Setting NUXT_BUNNY_API_KEY automatically activates the Bunny provider.
# NUXT_BUNNY_API_KEY=
# NUXT_BUNNY_STORAGE_ZONE=
# NUXT_BUNNY_PULL_ZONE=

# Email provider: console | cloudflare | resend | brevo | zepto | smtp
# 'cloudflare' needs no API key — see the send_email binding in wrangler.toml instead.
# 'smtp' actually means MailChannels (requires an existing MailChannels account +
# DNS domain-lockdown records) — not a generic SMTP relay, no host/user/pass to set.
NUXT_EMAIL_PROVIDER=console
NUXT_RESEND_API_KEY=
NUXT_BREVO_API_KEY=
NUXT_ZEPTO_API_KEY=

# Public (exposed to client)
NUXT_PUBLIC_SITE_URL=http://localhost:8787
NUXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
